NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/replate

# Auth
JWT_SECRET=your_jwt_secret_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase (push notifications)
# Paste the entire service account JSON as a single-line string, or
# set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON file
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
